# ──────────────────────────────────────────────────────────────────────────────
# BTU Virtual University – Environment Variables
# Copy to .env and fill in your real values. NEVER commit secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── Anthropic (REQUIRED) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY

# ── Models ────────────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-6
HAIKU_MODEL=claude-haiku-4-5
THINKING_BUDGET=8000

# ── Embedding (sentence-transformers, free & local) ──────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Local PostgreSQL ────────────────────────────────────────────────────────
# Install PostgreSQL locally, create database BTU_VU via pgAdmin or psql
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/BTU_VU

# ── FAISS Vector Store (local persistent, no server needed) ──────────────────
FAISS_PERSIST_DIR=.faiss_store

# ── JWT Authentication ────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── RAG Settings ────────────────────────────────────────────────────────────
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5
RAG_THRESHOLD=0.30

# ── Sprint Settings ────────────────────────────────────────────────────────
SPRINT_TARGET_HOURS=15.0
SUMMARISE_EVERY_N=5

# ── Server Settings ────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
